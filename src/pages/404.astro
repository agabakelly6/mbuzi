---
// src/pages/404.astro
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Button from "../components/ui/Button.astro";
import Footer from "../components/layout/Footer.astro";
import { SITE } from "../config/site";
---

<Layout
  title="Page Not Found"
  description={`The page you're looking for doesn't exist on ${SITE.name}.`}
  robots="noindex, follow"
>
  <Navbar />
  <main id="main-content">
    <section class="flex min-h-[70vh] items-center justify-center bg-[#14100D] px-6 py-24 text-center">
      <div class="mx-auto max-w-xl">
        <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">404</p>
        <h1 class="mt-4 font-serif text-3xl font-semibold text-white sm:text-4xl">Page Not Found</h1>
        <p class="mt-4 text-base text-white/65">
          The page you're looking for doesn't exist or may have moved.
        </p>
        <div class="mt-8 flex justify-center">
          <Button href="/" variant="solid" size="md">Back To Home</Button>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
