---
// src/pages/menu/index.astro
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Hero from "../../components/hero/Hero.astro";
import { MenuCategories } from "../../components/sections/MenuCategories";
import MenuGrid from "../../components/sections/MenuGrid.astro";
import ChefRecommendation from "../../components/sections/ChefRecommendation.astro";
import FoodQualityStory from "../../components/sections/FoodQualityStory.astro";
import CTASection from "../../components/sections/CTASection.astro";
import Footer from "../../components/layout/Footer.astro";
import { MENU_SECTIONS } from "../../data/menu-sections";
import {
  BREAKFAST_ITEMS,
  MAIN_COURSE_ITEMS,
  BURGER_ITEMS,
  SANDWICH_ITEMS,
  PIZZA_ITEMS,
  LUSANIYA_ITEMS,
  SMOOTHIE_ITEMS,
  DRINK_ITEMS,
} from "../../data/menu";
import { MENU_CONTENT } from "../../content/menu";
import { getPageStructuredData } from "../../config/seo";

const { hero, categorySections, cta } = MENU_CONTENT;
---

<Layout
  title={MENU_CONTENT.seo.title}
  description={MENU_CONTENT.seo.description}
  structuredData={getPageStructuredData({
    canonicalURL: Astro.url.href,
    name: MENU_CONTENT.seo.title,
    description: MENU_CONTENT.seo.description,
    breadcrumbs: [
      { name: "Home", url: `${Astro.url.origin}/` },
      { name: "Menu", url: Astro.url.href },
    ],
    includeMenu: true,
  })}
>
  <Navbar />
  <main id="main-content">
    <Hero
      eyebrow={hero.eyebrow}
      mottoLines={hero.headline}
      supportingText={hero.description}
      posterSrc={hero.image}
      posterAlt={hero.imageAlt}
      heightClass="h-[60vh]"
      exploreHref="#breakfast"
      exploreLabel={hero.secondaryCta?.label}
      nextSectionId="breakfast"
    />

    <MenuCategories client:load sections={MENU_SECTIONS} />

    <MenuGrid
      id="breakfast"
      eyebrow={categorySections.breakfast.eyebrow}
      heading={categorySections.breakfast.heading}
      items={BREAKFAST_ITEMS}
      tone="light"
    />
    <MenuGrid
      id="main-course"
      eyebrow={categorySections["main-course"].eyebrow}
      heading={categorySections["main-course"].heading}
      items={MAIN_COURSE_ITEMS}
      tone="dark"
    />
    <MenuGrid
      id="burgers"
      eyebrow={categorySections.burgers.eyebrow}
      heading={categorySections.burgers.heading}
      items={BURGER_ITEMS}
      tone="light"
    />
    <MenuGrid
      id="sandwiches"
      eyebrow={categorySections.sandwiches.eyebrow}
      heading={categorySections.sandwiches.heading}
      items={SANDWICH_ITEMS}
      tone="dark"
    />
    <MenuGrid
      id="pizza"
      eyebrow={categorySections.pizza.eyebrow}
      heading={categorySections.pizza.heading}
      items={PIZZA_ITEMS}
      tone="light"
    />
    <MenuGrid
      id="lusaniya"
      eyebrow={categorySections.lusaniya.eyebrow}
      heading={categorySections.lusaniya.heading}
      items={LUSANIYA_ITEMS}
      tone="dark"
    />
    <MenuGrid
      id="smoothies"
      eyebrow={categorySections.smoothies.eyebrow}
      heading={categorySections.smoothies.heading}
      items={SMOOTHIE_ITEMS}
      tone="light"
    />
    <MenuGrid
      id="drinks"
      eyebrow={categorySections.drinks.eyebrow}
      heading={categorySections.drinks.heading}
      items={DRINK_ITEMS}
      tone="dark"
    />

    <ChefRecommendation />
    <FoodQualityStory />
    <CTASection headline={cta.headline} supportingText={cta.description} />
  </main>
  <Footer />
</Layout>