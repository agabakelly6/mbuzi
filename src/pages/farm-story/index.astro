---
// src/pages/farm-story/index.astro
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Hero from "../../components/hero/Hero.astro";
import StorySplit from "../../components/sections/StorySplit.astro";
import FarmTimeline from "../../components/sections/FarmTimeline.astro";
import FarmGalleryPreview from "../../components/sections/FarmGalleryPreview.astro";
import WhyFarmToTable from "../../components/sections/WhyFarmToTable.astro";
import MeetTheTeam from "../../components/sections/MeetTheTeam.astro";
import Sustainability from "../../components/sections/Sustainability.astro";
import CTASection from "../../components/sections/CTASection.astro";
import Footer from "../../components/layout/Footer.astro";
import { BRAND_STORY_IMAGE } from "../../data/farm-story";
import { FARM_STORY_CONTENT } from "../../content/farm-story";
import { getPageStructuredData } from "../../config/seo";

const { hero, brandStory, cta } = FARM_STORY_CONTENT;
---

<Layout
  title={FARM_STORY_CONTENT.seo.title}
  description={FARM_STORY_CONTENT.seo.description}
  structuredData={getPageStructuredData({
    canonicalURL: Astro.url.href,
    name: FARM_STORY_CONTENT.seo.title,
    description: FARM_STORY_CONTENT.seo.description,
    breadcrumbs: [
      { name: "Home", url: `${Astro.url.origin}/` },
      { name: "Farm Story", url: Astro.url.href },
    ],
  })}
>
  <Navbar />
  <main>
    <Hero
      eyebrow={hero.eyebrow}
      mottoLines={hero.headline}
      supportingText={hero.description}
      heightClass="h-[70vh]"
      nextSectionId="brand-story"
    />

    <StorySplit
      id="brand-story"
      eyebrow={brandStory.eyebrow}
      heading={brandStory.heading}
      body={brandStory.description}
      imageSrc={BRAND_STORY_IMAGE.src}
      imageAlt={BRAND_STORY_IMAGE.alt}
      buttonHref="/menu"
      buttonLabel={brandStory.cta?.label ?? "See What We Grill"}
      imagePosition="left"
    />

    <FarmTimeline />
    <FarmGalleryPreview />
    <WhyFarmToTable />
    <MeetTheTeam />
    <Sustainability />

    <CTASection
      headline={cta.headline}
      supportingText={cta.description}
      secondary={{ label: cta.secondaryCta.label, href: "/menu" }}
    />
  </main>
  <Footer />
</Layout>