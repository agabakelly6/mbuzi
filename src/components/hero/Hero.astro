---
// src/components/hero/Hero.astro
//
// Reusable, full-bleed page hero. Every page passes its own posterSrc
// (and posterAlt) — Home, Menu, Farm Story, Gallery, Locations, Booking,
// Catering, and Contact each have their own cinematic image sourced from
// their content/*.ts hero object. The defaults below exist only as a
// safety fallback for a page that forgets to pass one — they are never
// the intended image for any real page.
//
// videoSrc is optional and has no default: only the homepage layers a
// video over its poster image today. When present, the video is only
// ever shown at `lg` and above — small screens always get the static
// poster image, both for data cost and because a full hero video rarely
// reads well on a phone-sized viewport.
import { HeroContent } from "./HeroContent";
import OptimizedImage from "../ui/OptimizedImage.astro";
import { NAV_CTAS, PRIMARY_NAV } from "../../data/navigation";
import { SITE } from "../../config/site";
import { resolveImageSrc } from "../../lib/images";

interface Props {
  eyebrow?: string;
  /** Pre-split display lines for the H1. Defaults to SITE.motto's two sentences. */
  mottoLines?: string[];
  supportingText?: string;
  posterSrc?: string;
  posterAlt?: string;
  videoSrc?: string;
  reserveHref?: string;
  reserveLabel?: string;
  exploreHref?: string;
  exploreLabel?: string;
  /** id on the section immediately below the hero — the scroll cue jumps here */
  nextSectionId?: string;
  /** Tailwind height utility. Defaults to a full 100vh hero per the wireframe. */
  heightClass?: string;
}

const defaultReserve = NAV_CTAS.find((cta) => cta.label === "Reserve Table");
const defaultMenuLink = PRIMARY_NAV.find((link) => link.label === "Menu");

// SITE.motto is one string ("Raised By Us. Grilled For You.") — split it
// into the two stacked display lines the wireframe calls for, rather than
// hardcoding the lines a second time in config/site.ts.
const defaultMottoLines = SITE.motto
  .split(". ")
  .map((line) => line.trim())
  .filter(Boolean)
  .map((line) => (line.endsWith(".") ? line : `${line}.`));

const {
  eyebrow = "Authentic Ugandan Goat Choma",
  mottoLines = defaultMottoLines,
  supportingText = "Farm fresh goat meat prepared with authentic Ugandan flavour.",
  // Safety fallback only — every real page passes its own posterSrc/posterAlt.
  posterSrc = "/images/hero/hero-main.webp",
  posterAlt = "",
  videoSrc,
  reserveHref = defaultReserve?.href ?? "/booking",
  reserveLabel = defaultReserve?.label ?? "Reserve Table",
  exploreHref = defaultMenuLink?.href ?? "/menu",
  exploreLabel = "Explore Menu",
  nextSectionId = "hero-next",
  heightClass = "h-screen",
} = Astro.props;

// The <video> element's `poster` attribute needs a plain URL (it can't
// render an Astro component), so it's resolved separately here — the
// <img> below handles its own resolution/placeholder fallback via
// OptimizedImage.
const resolvedPosterSrc = await resolveImageSrc(posterSrc);
---

<section
  aria-labelledby="hero-heading"
  class={`relative flex w-full items-center justify-center overflow-hidden bg-[#14100D] ${heightClass}`}
>
  {/* Background layer: static poster paints instantly (and is the LCP
      candidate); video fades in on top once it can play. Pure CSS drives
      both the slow Ken Burns scale and the reduced-motion fallback, so
      none of it costs a byte of JS. */}
  <div class="hero-media absolute inset-0 h-full w-full">
    <OptimizedImage
      src={posterSrc}
      alt={posterAlt}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    {
      videoSrc && (
        // Desktop/large-screen only — phones always see the static poster
        // image above, never the video.
        <video
          class="hero-video absolute inset-0 hidden h-full w-full object-cover lg:block"
          src={videoSrc}
          poster={resolvedPosterSrc}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        />
      )
    }
  </div>

  <div
    class="absolute inset-0 bg-gradient-to-b from-[#14100D]/35 via-[#14100D]/55 to-[#14100D]/85"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 [background:radial-gradient(ellipse_at_center,transparent_35%,rgba(20,16,13,0.5)_100%)]"
    aria-hidden="true"
  ></div>

  <HeroContent
    client:load
    headingId="hero-heading"
    eyebrow={eyebrow}
    mottoLines={mottoLines}
    supportingText={supportingText}
    reserveHref={reserveHref}
    reserveLabel={reserveLabel}
    exploreHref={exploreHref}
    exploreLabel={exploreLabel}
    nextSectionId={nextSectionId}
  />
</section>

<style>
  .hero-media {
    animation: hero-zoom 20s ease-out forwards;
    transform-origin: center;
    will-change: transform;
  }

  @keyframes hero-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media {
      animation: none;
    }
    .hero-video {
      display: none;
    }
  }
</style>