---
// src/components/ui/OptimizedImage.astro
//
// Drop-in replacement for a plain <img src={path} alt={alt} class={c} />
// in any .astro file. Resolves `src` through lib/images.ts: a real photo
// that's been added to src/assets/ renders through astro:assets' <Image>
// (genuinely resized/format-converted, not just relabeled); a path that
// hasn't been sourced yet renders a plain placeholder panel instead of a
// broken-image icon, so the site never looks broken while real
// photography is still being gathered. One shared fallback treatment
// instead of every caller inventing its own.
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/images";

interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const { src, alt, class: className, loading = "lazy", fetchpriority = "auto" } = Astro.props;
const resolved = resolveImage(src);
---

{
  resolved ? (
    <Image src={resolved} alt={alt} class={className} loading={loading} fetchpriority={fetchpriority} />
  ) : (
    <div class={`bg-[#C89A4B]/10 ${className ?? ""}`} role="img" aria-label={alt} />
  )
}
