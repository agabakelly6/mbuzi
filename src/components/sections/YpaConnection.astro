---
// src/components/sections/YpaConnection.astro
//
// Short, text-only explanation of how the restaurant connects to Youth
// Platform Africa — deliberately no image, so it reads as a distinct
// aside rather than competing visually with FounderMessage right above
// it. External CTA links out to the official YPA site.
import FadeIn from "../animations/FadeIn.astro";
import Button from "../ui/Button.astro";
import { FARM_STORY_CONTENT } from "../../content/farm-story";

const { eyebrow, heading, description, cta } = FARM_STORY_CONTENT.ypaConnection;
---

<section
  id="ypa-connection"
  aria-labelledby="ypa-connection-heading"
  class="scroll-mt-36 bg-white py-20 sm:py-28 lg:scroll-mt-40"
>
  <div class="mx-auto max-w-2xl px-6 text-center lg:px-12">
    <FadeIn>
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="ypa-connection-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
      {description && <p class="mt-6 text-base leading-relaxed text-[#14100D]/70">{description}</p>}
      {
        cta?.href && (
          <div class="mt-8">
            <Button href={cta.href} variant="outline" tone="light" size="md" external>
              {cta.label}
            </Button>
          </div>
        )
      }
    </FadeIn>
  </div>
</section>
