---
// src/components/sections/BusinessHours.astro
import { SITE } from "../../config/site";
import { RESPONSE_EXPECTATIONS } from "../../data/contact";
import FadeIn from "../animations/FadeIn.astro";

interface Props {
  eyebrow: string;
  heading: string;
  responseHeading: string;
}

const { eyebrow, heading, responseHeading } = Astro.props;
---

<section
  id="business-hours"
  aria-labelledby="business-hours-heading"
  class="scroll-mt-36 bg-[#F5EFE4] py-20 sm:py-28 lg:scroll-mt-40"
>
  <div class="mx-auto max-w-[900px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="business-hours-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2">
      <FadeIn className="rounded-2xl border border-[#14100D]/10 bg-white p-6">
        <h3 class="font-serif text-lg font-semibold text-[#14100D]">{heading}</h3>
        <dl class="mt-4 flex flex-col gap-3 text-sm text-[#14100D]/75">
          {
            SITE.hours.map((entry) => (
              <div class="flex justify-between gap-4">
                <dt>{entry.days}</dt>
                <dd class="font-medium text-[#14100D]">{entry.hours}</dd>
              </div>
            ))
          }
        </dl>
      </FadeIn>

      <FadeIn delay={0.08} className="rounded-2xl border border-[#14100D]/10 bg-white p-6">
        <h3 class="font-serif text-lg font-semibold text-[#14100D]">{responseHeading}</h3>
        <dl class="mt-4 flex flex-col gap-3 text-sm text-[#14100D]/75">
          {
            RESPONSE_EXPECTATIONS.map((entry) => (
              <div class="flex justify-between gap-4">
                <dt>{entry.channel}</dt>
                <dd class="text-right font-medium text-[#14100D]">{entry.expectation}</dd>
              </div>
            ))
          }
        </dl>
      </FadeIn>
    </div>
  </div>
</section>