---
// src/components/sections/StorySplit.astro
//
// Shared image+copy split layout. FarmStoryPreview (homepage) and
// FoodQualityStory (menu page) are both thin content wrappers around
// this — the layout, spacing, and reveal animation live in exactly one
// place instead of being copy-pasted between two files.
import FadeIn from "../animations/FadeIn.astro";
import Button from "../ui/Button.astro";
import OptimizedImage from "../ui/OptimizedImage.astro";

interface Props {
  id: string;
  eyebrow: string;
  heading: string;
  body: string;
  imageSrc: string;
  imageAlt: string;
  buttonHref: string;
  buttonLabel: string;
  /** Which side the image sits on at desktop width. Defaults to left. */
  imagePosition?: "left" | "right";
  /**
   * Extra classes for the root <section> — used by menu-page callers to
   * add scroll-margin-top for the sticky quick-nav. Left empty by
   * default since the homepage doesn't have a sticky sub-nav to offset.
   */
  sectionClass?: string;
}

const {
  id,
  eyebrow,
  heading,
  body,
  imageSrc,
  imageAlt,
  buttonHref,
  buttonLabel,
  imagePosition = "left",
  sectionClass = "",
} = Astro.props;

const imageOrderClass = imagePosition === "left" ? "order-2 lg:order-1" : "order-2 lg:order-2";
const textOrderClass = imagePosition === "left" ? "order-1 lg:order-2" : "order-1 lg:order-1";
---

<section
  id={id}
  aria-labelledby={`${id}-heading`}
  class={`relative overflow-hidden bg-[#14100D] py-20 sm:py-28 ${sectionClass}`}
>
  <div class="mx-auto grid max-w-[1280px] grid-cols-1 items-center gap-12 px-6 lg:grid-cols-2 lg:gap-16 lg:px-12">
    <FadeIn y={32} className={`overflow-hidden rounded-2xl ${imageOrderClass}`}>
      <OptimizedImage
        src={imageSrc}
        alt={imageAlt}
        loading="lazy"
        class="aspect-[4/5] w-full object-cover"
      />
    </FadeIn>

    <FadeIn className={textOrderClass}>
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id={`${id}-heading`}
        class="mt-4 font-serif text-3xl font-semibold text-white sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
      <p class="mt-6 max-w-lg text-base leading-relaxed text-white/70">{body}</p>
      <div class="mt-8">
        <Button href={buttonHref} variant="outline" tone="dark" size="md">
          {buttonLabel}
        </Button>
      </div>
    </FadeIn>
  </div>
</section>
