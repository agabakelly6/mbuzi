---
// src/components/sections/PillarGrid.astro
//
// Shared icon+title+description pillar-grid layout. WhyFarmToTable.astro
// (farm story) is a thin wrapper around this; WhyChooseYPA.astro
// (catering) is the second. Same reasoning as ImageGrid/StorySplit — one
// layout implementation, not a third copy-pasted grid.
import FadeIn from "../animations/FadeIn.astro";
import type { ComponentType, SVGProps } from "react";

interface Pillar {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  id: string;
  eyebrow: string;
  heading: string;
  pillars: Pillar[];
  /** Maps each pillar's `icon` key to a lucide-react icon component. */
  icons: Record<string, ComponentType<SVGProps<SVGSVGElement>>>;
  tone?: "light" | "dark";
  /** Grid column count at the lg breakpoint. */
  columns?: 4 | 5;
}

const { id, eyebrow, heading, pillars, icons, tone = "dark", columns = 4 } = Astro.props;
const isDark = tone === "dark";
const colsClass = columns === 5 ? "sm:grid-cols-2 lg:grid-cols-5" : "sm:grid-cols-2 lg:grid-cols-4";
---

<section
  id={id}
  aria-labelledby={`${id}-heading`}
  class:list={[
    "scroll-mt-36 py-20 sm:py-28 lg:scroll-mt-40",
    isDark ? "bg-[#14100D]" : "bg-white",
  ]}
>
  <div class="mx-auto max-w-[1280px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id={`${id}-heading`}
        class:list={[
          "mt-4 font-serif text-3xl font-semibold sm:text-4xl lg:text-[42px]",
          isDark ? "text-white" : "text-[#14100D]",
        ]}
      >
        {heading}
      </h2>
    </FadeIn>

    <div class:list={["mt-14 grid grid-cols-1 gap-8", colsClass]}>
      {
        pillars.map((pillar, index) => {
          const Icon = icons[pillar.icon];
          return (
            <FadeIn delay={index * 0.08} className="text-center">
              <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full border border-[#C89A4B]/30">
                <Icon className="h-5 w-5 text-[#C89A4B]" strokeWidth={1.5} aria-hidden="true" />
              </span>
              <h3
                class:list={[
                  "mt-5 font-serif text-lg font-semibold",
                  isDark ? "text-white" : "text-[#14100D]",
                ]}
              >
                {pillar.title}
              </h3>
              <p
                class:list={[
                  "mt-2 text-sm leading-relaxed",
                  isDark ? "text-white/65" : "text-[#14100D]/65",
                ]}
              >
                {pillar.description}
              </p>
            </FadeIn>
          );
        })
      }
    </div>
  </div>
</section>