---
// src/components/sections/MeetTheTeam.astro
//
// One unified grid rather than three separate Farmers/Chefs/Restaurant
// Team subsections — reads as "one family" rather than an HR org chart,
// which fits the brand's warm tone better. Each card still carries its
// group as a small label under the role.
//
// Joins TEAM_ROSTER (role/group — a people/org concern, in
// data/farm-story.ts) with TEAM_IMAGES (name/photo — a media concern, in
// media/team.ts) by id, rather than either file duplicating the other's
// data.
import { TEAM_ROSTER } from "../../data/farm-story";
import { FARM_STORY_CONTENT } from "../../content/farm-story";
import { TEAM_IMAGES } from "../../media/team";
import FadeIn from "../animations/FadeIn.astro";

const { eyebrow, heading } = FARM_STORY_CONTENT.meetTheTeam;

const team = TEAM_ROSTER.map((entry) => {
  const image = TEAM_IMAGES.find((img) => img.id === entry.imageId);
  return {
    name: image?.title ?? "",
    photo: image?.src ?? "",
    alt: image?.alt ?? "",
    role: entry.role,
    group: entry.group,
  };
});
---

<section
  id="meet-the-team"
  aria-labelledby="meet-the-team-heading"
  class="scroll-mt-36 bg-white py-20 sm:py-28 lg:scroll-mt-40"
>
  <div class="mx-auto max-w-[1280px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">
        {eyebrow}
      </p>
      <h2
        id="meet-the-team-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-14 grid grid-cols-2 gap-x-6 gap-y-12 sm:grid-cols-3 lg:grid-cols-6">
      {
        team.map((member, index) => (
          <FadeIn delay={index * 0.06} className="text-center">
            <div class="mx-auto aspect-square w-full max-w-[140px] overflow-hidden rounded-full">
              <img
                src={member.photo}
                alt={member.alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover"
              />
            </div>
            <h3 class="mt-4 font-serif text-base font-semibold text-[#14100D]">{member.name}</h3>
            <p class="mt-1 text-[11px] font-semibold uppercase tracking-[0.1em] text-[#C89A4B]">
              {member.role}
            </p>
            <p class="mt-0.5 text-[11px] text-[#14100D]/45">{member.group}</p>
          </FadeIn>
        ))
      }
    </div>
  </div>
</section>