---
// src/components/sections/PaymentOptions.astro
//
// Purely informational — displays real merchant codes for guests to
// dial themselves via their mobile money app/USSD. No "Pay Now" button,
// no payment gateway, no fake transaction — there's no payment
// processor integrated, and pretending otherwise would be dishonest.
import { MERCHANT_PAYMENT_OPTIONS } from "../../data/booking";
import FadeIn from "../animations/FadeIn.astro";

interface Props {
  eyebrow: string;
  heading: string;
  description?: string;
}

const { eyebrow, heading, description } = Astro.props;
---

<section
  id="payment"
  aria-labelledby="payment-heading"
  class="scroll-mt-36 bg-[#14100D] py-20 sm:py-28 lg:scroll-mt-40"
>
  <div class="mx-auto max-w-[1000px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="payment-heading"
        class="mt-4 font-serif text-3xl font-semibold text-white sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
      {description && <p class="mt-4 text-base text-white/65">{description}</p>}
    </FadeIn>

    <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        MERCHANT_PAYMENT_OPTIONS.map((option, index) => (
          <FadeIn
            delay={index * 0.1}
            className="rounded-2xl border border-white/10 bg-white/[0.03] p-6"
          >
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-[#C89A4B]">
              {option.provider}
            </p>
            <p class="mt-3 font-mono text-3xl font-semibold tracking-wider text-white select-all">
              {option.merchantCode}
            </p>
            <p class="mt-1 text-sm text-white/50">{option.merchantName}</p>
            <p class="mt-4 text-sm leading-relaxed text-white/65">{option.instructions}</p>
          </FadeIn>
        ))
      }
    </div>

    <p class="mt-8 text-center text-xs text-white/40">
      Cash is accepted for dining in person — not to hold a reservation remotely.
    </p>
  </div>
</section>