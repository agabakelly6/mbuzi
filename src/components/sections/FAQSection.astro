---
// src/components/sections/FAQSection.astro
//
// Native <details>/<summary> rather than a React accordion — expand/
// collapse, keyboard operation, and screen-reader semantics all come
// free from the browser, at zero client JS. Tradeoff: no slide-height
// animation on open/close (native <details> doesn't animate cleanly
// across browsers without extra JS). If that specific motion matters
// enough to be worth the JS cost, this is the one place on the page
// that would need to become a React island instead.
import { ChevronDown } from "lucide-react";
import FadeIn from "../animations/FadeIn.astro";
import type { FAQItem } from "../../types/content";

interface Props {
  eyebrow: string;
  heading: string;
  items: FAQItem[];
}

const { eyebrow, heading, items } = Astro.props;
---

<section id="faq" aria-labelledby="faq-heading" class="scroll-mt-36 bg-white py-20 sm:py-28 lg:scroll-mt-40">
  <div class="mx-auto max-w-3xl px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="faq-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
    </FadeIn>

    <div class="mt-12 flex flex-col divide-y divide-[#14100D]/10 border-t border-b border-[#14100D]/10">
      {
        items.map((item) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-serif text-lg font-semibold text-[#14100D] marker:content-none">
              {item.question}
              <ChevronDown
                className="h-5 w-5 shrink-0 text-[#C89A4B] transition-transform duration-300 group-open:rotate-180"
                aria-hidden="true"
              />
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-[#14100D]/65">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>