---
// src/components/sections/LocationsMap.astro
//
// Deliberately abstracted from any specific map provider. Renders each
// branch as a positioned pin (from real lat/lng in data/locations.ts) on
// a stylized static panel — zero client JS, and every pin already links
// to real driving directions today. When a real interactive map is
// wanted, swap the contents of #map-canvas for a Google Maps/Leaflet
// mount and keep feeding it the same `locations` prop — nothing else on
// the page needs to change, since coordinates are never hardcoded here.
import { MapPin } from "lucide-react";
import type { Location } from "../../types/location";
import FadeIn from "../animations/FadeIn.astro";

interface Props {
  locations: Location[];
  eyebrow: string;
  heading: string;
}

const { locations, eyebrow, heading } = Astro.props;

// Rough bounding box for Uganda, used only to place decorative pins
// proportionally on the placeholder panel — has no bearing on the real
// coordinates in data/locations.ts, which is exactly what a real map
// SDK would consume directly instead of this normalization.
const BOUNDS = { minLat: -1.5, maxLat: 4.2, minLng: 29.5, maxLng: 35.0 };

function toPosition(lat: number, lng: number) {
  const x = ((lng - BOUNDS.minLng) / (BOUNDS.maxLng - BOUNDS.minLng)) * 100;
  const y = 100 - ((lat - BOUNDS.minLat) / (BOUNDS.maxLat - BOUNDS.minLat)) * 100;
  return { x: Math.min(94, Math.max(6, x)), y: Math.min(88, Math.max(12, y)) };
}

/**
 * Real, geographically-close branches (e.g. several Kampala-area
 * locations) can land within a pin's width of each other once projected
 * onto this small placeholder panel, making them visually overlap or
 * stack unreadably. This spreads any such cluster into a small horizontal
 * line around its shared center — display-only, never touches the real
 * coordinates above, which is what a future real map SDK would consume
 * directly instead of this normalization.
 */
function declusterPositions(positions: { x: number; y: number }[]): { x: number; y: number }[] {
  const CLUSTER_THRESHOLD = 4; // percentage-space distance under which pins are considered overlapping
  // Percentage-space spacing between clustered pins. Sized for the
  // narrowest supported viewport (~272px usable map width at 320px),
  // where anything much smaller still visually overlaps a 36px pin —
  // verified against real branch data that this stays clear of Maddu's
  // unclustered position (~15 points further away).
  const SPREAD = 7;
  const result = positions.map((p) => ({ ...p }));
  const visited = new Set<number>();

  for (let i = 0; i < result.length; i++) {
    if (visited.has(i)) continue;
    const cluster = [i];
    for (let j = i + 1; j < result.length; j++) {
      if (visited.has(j)) continue;
      const dx = result[i].x - result[j].x;
      const dy = result[i].y - result[j].y;
      if (Math.sqrt(dx * dx + dy * dy) < CLUSTER_THRESHOLD) cluster.push(j);
    }
    if (cluster.length > 1) {
      cluster.forEach((idx) => visited.add(idx));
      const centerX = cluster.reduce((sum, idx) => sum + result[idx].x, 0) / cluster.length;
      cluster.forEach((idx, order) => {
        const offset = (order - (cluster.length - 1) / 2) * SPREAD;
        result[idx].x = Math.min(94, Math.max(6, centerX + offset));
      });
    }
  }

  return result;
}

const pinPositions = declusterPositions(
  locations.map((location) => toPosition(location.coordinates.lat, location.coordinates.lng))
);
---

<section id="map" aria-labelledby="map-heading" class="scroll-mt-36 bg-white py-20 sm:py-28 lg:scroll-mt-40">
  <div class="mx-auto max-w-[1280px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="map-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
    </FadeIn>

    {
      /*
        #map-canvas is the intended mount point for a future Leaflet/
        Google Maps instance. Until then it's a static, styled panel with
        real, working pins — not a fake loading state.
      */
    }
    <div
      id="map-canvas"
      data-locations-count={locations.length}
      class="relative mt-14 aspect-[16/10] w-full overflow-hidden rounded-2xl border border-[#14100D]/10 bg-[#F5EFE4] sm:aspect-[16/7]"
    >
      <div
        class="absolute inset-0 [background-image:radial-gradient(#14100d14_1px,transparent_1px)] [background-size:24px_24px]"
        aria-hidden="true"
      >
      </div>

      {
        locations.map((location, index) => {
          const { x, y } = pinPositions[index];
          const isComingSoon = location.status === "coming-soon";
          return (
            <a
              href={location.googleMapsLink}
              target="_blank"
              rel="noopener noreferrer"
              class="group absolute -translate-x-1/2 -translate-y-full"
              style={`left:${x}%; top:${y}%;`}
              aria-label={`Get directions to ${location.name}${isComingSoon ? " (opening soon)" : ""}`}
            >
              <span
                class:list={[
                  "flex h-9 w-9 items-center justify-center rounded-full border-2 shadow-lg transition-transform duration-300 group-hover:scale-110",
                  isComingSoon
                    ? "border-[#C89A4B] border-dashed bg-white text-[#C89A4B]"
                    : "border-white bg-[#C89A4B] text-[#14100D]",
                ]}
              >
                <MapPin className="h-4 w-4" strokeWidth={2} aria-hidden="true" />
              </span>
              <span class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2 whitespace-nowrap rounded-full bg-[#14100D] px-3 py-1 text-[11px] font-semibold text-white opacity-0 shadow-lg transition-opacity duration-300 group-hover:opacity-100 group-hover:z-20 group-focus-visible:opacity-100 group-focus-visible:z-20">
                {location.city}
                {isComingSoon && " · Opening Soon"}
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>