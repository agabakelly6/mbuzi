---
// src/components/sections/MenuGrid.astro
//
// One reusable category section, invoked once per category from
// pages/menu/index.astro — Breakfast, Main Course, Burgers, Sandwiches,
// Pizza, Lusaniya, Smoothies, and Drinks all render through this instead
// of eight near-identical files. Items with a `subcategory` (Drinks) are
// grouped under their own sub-heading; everything else renders as one
// flat grid, as it always did.
import type { MenuItem } from "../../data/menu";
import { FoodCard } from "../cards/FoodCard";
import FadeIn from "../animations/FadeIn.astro";
import { resolveImageSrc } from "../../lib/images";

interface Props {
  id: string;
  eyebrow: string;
  heading: string;
  items: MenuItem[];
  tone?: "light" | "dark";
}

const { id, eyebrow, heading, items, tone = "light" } = Astro.props;
const isDark = tone === "dark";

// FoodCard is a plain React component and can't call astro:assets itself,
// so every item's image is resolved to a final optimized URL here first.
const imageSrcById = new Map(
  await Promise.all(items.map(async (item) => [item.id, await resolveImageSrc(item.image)] as const))
);

// Groups items by subcategory when present (e.g. Drinks: Milkshakes, Tea
// & Hot Drinks, Juices...), preserving first-seen order. Categories with
// no subcategories render as a single unlabeled group — the flat grid
// this always used to be.
const groups = items.reduce<{ label: string | null; items: typeof items }[]>((acc, item) => {
  const label = item.subcategory ?? null;
  const existing = acc.find((group) => group.label === label);
  if (existing) {
    existing.items.push(item);
  } else {
    acc.push({ label, items: [item] });
  }
  return acc;
}, []);
---

<section
  id={id}
  aria-labelledby={`${id}-heading`}
  class:list={[
    "scroll-mt-36 py-20 sm:py-28 lg:scroll-mt-40",
    isDark ? "bg-[#14100D]" : "bg-white",
  ]}
>
  <div class="mx-auto max-w-[1280px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">
        {eyebrow}
      </p>
      <h2
        id={`${id}-heading`}
        class:list={[
          "mt-4 font-serif text-3xl font-semibold sm:text-4xl lg:text-[42px]",
          isDark ? "text-white" : "text-[#14100D]",
        ]}
      >
        {heading}
      </h2>
    </FadeIn>

    {
      groups.map((group) => (
        <>
          {group.label && (
            <FadeIn>
              <h3
                class:list={[
                  "mt-14 font-serif text-xl font-semibold",
                  isDark ? "text-white" : "text-[#14100D]",
                ]}
              >
                {group.label}
              </h3>
            </FadeIn>
          )}
          <div
            class:list={[
              "grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4",
              group.label ? "mt-8" : "mt-14",
            ]}
          >
            {group.items.map((item, index) => (
              <FadeIn delay={index * 0.08}>
                <FoodCard
                  client:visible
                  item={item}
                  imageSrc={imageSrcById.get(item.id)}
                  tone={tone}
                  showCta={false}
                  orderable
                />
              </FadeIn>
            ))}
          </div>
        </>
      ))
    }
  </div>
</section>
