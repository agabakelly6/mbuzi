---
// src/components/sections/FutureExpansion.astro
//
// Roadmap section — distinct from LocationsGrid/LocationCard on purpose.
// Those drive real booking and directions for open branches; a planned
// city has neither yet, so it gets a lighter "Planned" card instead of
// being forced into the same booking-ready treatment.
import FadeIn from "../animations/FadeIn.astro";
import { PLANNED_LOCATIONS } from "../../data/expansion";

interface Props {
  eyebrow: string;
  heading: string;
  description?: string;
}

const { eyebrow, heading, description } = Astro.props;
---

<section
  id="future-expansion"
  aria-labelledby="future-expansion-heading"
  class="scroll-mt-36 bg-[#F5EFE4] py-20 sm:py-28 lg:scroll-mt-40"
>
  <div class="mx-auto max-w-[1280px] px-6 lg:px-12">
    <FadeIn className="mx-auto max-w-2xl text-center">
      <p class="text-[12px] font-semibold uppercase tracking-[0.28em] text-[#C89A4B]">{eyebrow}</p>
      <h2
        id="future-expansion-heading"
        class="mt-4 font-serif text-3xl font-semibold text-[#14100D] sm:text-4xl lg:text-[42px]"
      >
        {heading}
      </h2>
      {description && <p class="mt-4 text-base text-[#14100D]/65">{description}</p>}
    </FadeIn>

    <div class="mx-auto mt-14 grid max-w-3xl grid-cols-1 gap-6 sm:grid-cols-2">
      {
        PLANNED_LOCATIONS.map((location) => (
          <FadeIn>
            <div class="rounded-2xl border border-dashed border-[#C89A4B]/40 bg-white p-6">
              <span class="inline-flex rounded-full border border-[#C89A4B]/50 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-[#C89A4B]">
                Planned
              </span>
              <h3 class="mt-4 font-serif text-xl font-semibold text-[#14100D]">{location.city}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[#14100D]/60">{location.note}</p>
            </div>
          </FadeIn>
        ))
      }
    </div>
  </div>
</section>
