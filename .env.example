# Copy this file to .env and fill in real values — .env is gitignored and never committed.

# Supabase project URL.
# Where to find it: Supabase Dashboard > Project Settings > API > Project URL
PUBLIC_SUPABASE_URL=

# Supabase anonymous/publishable key.
# Where to find it: Supabase Dashboard > Project Settings > API > anon public key
# Safe to expose in client-side code (the `PUBLIC_` prefix ships it to the browser
# bundle deliberately) — access control comes from Row Level Security policies on
# each table, not from keeping this key secret.
#
# Never put the service_role/secret key here or anywhere under PUBLIC_ — that key
# bypasses Row Level Security and must only ever be used from a trusted server
# context, which this project does not have yet (static output, no adapter).
PUBLIC_SUPABASE_ANON_KEY=
